{
  "name": "badminton-server",
  "version": "1.0.0",
  "private": true,
  "description": "Backend for the badminton activity WeChat mini-program (signup, quota, waitlist, auto-promote).",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "start": "node scripts/sync-dev-url.js && node src/index.js",
    "dev": "node scripts/sync-dev-url.js && node --watch src/index.js",
    "sync-dev-url": "node scripts/sync-dev-url.js",
    "test": "node --test tests/*.test.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "qrcode": "^1.5.4"
  }
}
