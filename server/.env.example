# Copy to .env and fill in. If WX_APPID / WX_SECRET are left blank the server
# runs in DEV MODE (see README) so you can develop without WeChat credentials.

# Server
PORT=3000
# Bind interface. Dev (no proxy): 0.0.0.0 so the phone/simulator can reach it.
# Prod (behind Nginx): 127.0.0.1 so only the proxy exposes it.
HOST=0.0.0.0
# CORS: comma-separated allowed origins. Mini-program requests aren't browser
# CORS requests, so this only affects web-based testing. Use * in dev.
CORS_ORIGIN=*

# Where the JSON database is written. In PROD use an ABSOLUTE path on
# persistent storage (outside the deploy dir) so redeploys don't wipe data.
DATA_FILE=./data/db.json

# Secret used to sign session tokens. Set to a long random string in prod:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=dev-change-me

# --- WeChat (code2session + QR codes) -------------------------------------
# Leave blank to enable dev mode. In real mode, set both from the WeChat MP console.
WX_APPID=
WX_SECRET=
# Which mini-program version the QR code (小程序码) opens into:
#   develop | trial | release. Default release. Use develop/trial before publish.
WX_ENV_VERSION=release

# --- Backups --------------------------------------------------------------
# Rotating db.json backups run on this interval (seconds). Default 3600 (1h).
BACKUP_INTERVAL_SECONDS=3600
# How many rotating .bak.N copies to keep. Default 10. Set < 1 to disable.
BACKUP_KEEP=10
