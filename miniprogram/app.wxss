/* ---- global ---- */
page {
  background: #f2f4f7;
  color: #1f2937;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
}

view,
text {
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.muted {
  color: #9ca3af;
  font-size: 26rpx;
}

.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  margin-left: 12rpx;
  vertical-align: middle;
}
.tag-full {
  background: #fee2e2;
  color: #dc2626;
}
.tag-open {
  background: #dcfce7;
  color: #16a34a;
}
.tag-wait {
  background: #fef3c7;
  color: #d97706;
}
.tag-closed {
  background: #f3f4f6;
  color: #6b7280;
}

.row {
  display: flex;
  align-items: center;
}
.between {
  justify-content: space-between;
}

.title-lg {
  font-size: 34rpx;
  font-weight: 600;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #374151;
}

/* ---- buttons ---- */
.btn {
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 22rpx 0;
  text-align: center;
  width: 100%;
}
.btn-primary {
  background: #16a34a;
  color: #fff;
}
.btn-primary[disabled] {
  background: #d1fae5;
  color: #fff;
}
.btn-danger {
  background: #fff;
  color: #dc2626;
  border: 2rpx solid #fecaca;
}
.btn-ghost {
  background: #f3f4f6;
  color: #374151;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background: #16a34a;
  color: #fff;
  font-size: 64rpx;
  line-height: 96rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(22, 163, 74, 0.4);
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 120rpx 0;
  font-size: 28rpx;
}

.input {
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}
.field-label {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 12rpx;
}
.field {
  margin-bottom: 28rpx;
}
