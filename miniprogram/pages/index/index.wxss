.quota {
  font-size: 26rpx;
}
.dim {
  opacity: 0.5;
}
.feed-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.feed-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
}
.feed-tab.on {
  background: #16a34a;
  color: #fff;
  font-weight: 600;
}
.feed-note {
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 20rpx;
}
