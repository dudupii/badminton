<view class="container">
  <button class="btn btn-ghost copy-btn" bindtap="copyLast">复制上一场</button>
  <view class="card">
    <view class="field">
      <view class="field-label">活动标题 *</view>
      <input
        class="input"
        placeholder="如：周三晚奥体打球"
        maxlength="40"
        value="{{title}}"
        data-field="title"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">组织者</view>
      <input
        class="input"
        placeholder="如：俱乐部名（默认你的昵称）"
        maxlength="32"
        value="{{organizer}}"
        data-field="organizer"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">地点</view>
      <input
        class="input"
        placeholder="如：奥体中心 5 号场地"
        maxlength="60"
        value="{{location}}"
        data-field="location"
        bindinput="onInput"
      />
    </view>

    <view class="field">
      <view class="field-label">开始时间 *</view>
      <picker mode="date" value="{{startDate}}" start="{{todayDate}}" bindchange="onStartDateChange" class="dt-picker">
        <view class="input">{{startDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{startTime}}" bindchange="onStartTimeChange" class="dt-picker dt-picker-gap">
        <view class="input">{{startTime}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">结束时间（可选）</view>
      <picker mode="date" value="{{endDate}}" start="{{todayDate}}" bindchange="onEndDateChange" class="dt-picker">
        <view class="input">{{endDate || '选择日期'}}</view>
      </picker>
      <picker mode="time" value="{{endTime}}" bindchange="onEndTimeChange" class="dt-picker dt-picker-gap">
        <view class="input">{{endTime}}</view>
      </picker>
    </view>

    <view class="field">
      <view class="field-label">名额 *</view>
      <input
        class="input"
        type="number"
        placeholder="如 8"
        value="{{capacity}}"
        bindinput="onCapacity"
      />
      <view class="muted" style="margin-top:10rpx;">超过名额的报名将自动进入候补</view>
    </view>

    <view class="field">
      <view class="field-label">活动说明（可选）</view>
      <textarea
        class="input"
        style="height:140rpx;"
        placeholder="费用分摊、水平要求、注意事项等"
        maxlength="200"
        value="{{description}}"
        data-field="description"
        bindinput="onInput"
      />
      <view class="muted" style="margin-top:10rpx;">填写后将在活动详情的日期与报名状态之后展示</view>
    </view>

    <view class="field" wx:if="{{!editId}}">
      <view class="field-label">重复</view>
      <picker bindchange="onRepeatChange" value="{{repeatMode}}" range="{{repeatOptions}}">
        <view class="input">{{repeatOptions[repeatMode]}}</view>
      </picker>
      <view wx:if="{{repeatMode !== 0}}" class="row" style="margin-top:16rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">生成场数</text>
        <input class="input" style="flex:1;" type="number" value="{{repeatCount}}" bindinput="onRepeatCountChange" bindblur="onRepeatCountBlur" />
      </view>
      <view wx:if="{{repeatMode === 3}}" class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">间隔天数</text>
        <input class="input" style="flex:1;" type="number" value="{{customStep}}" bindinput="onCustomStepChange" bindblur="onCustomStepBlur" />
      </view>
      <view wx:if="{{repeatMode !== 0}}" class="muted" style="margin-top:10rpx;">将按所选间隔一次性生成多场（同标题/地点/名额），最多 12 场</view>
    </view>

    <view class="field">
      <view class="field-label">报名规则（可选）</view>

      <view class="row" style="margin-top:12rpx;align-items:center;">
        <switch checked="{{ruleNoShow}}" bindchange="toggleRuleNoShow" color="#16a34a"/>
        <text style="margin-left:16rpx;">缺席惩罚</text>
      </view>
      <view wx:if="{{ruleNoShow}}" class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">缺席后禁报天数</text>
        <input class="input" style="flex:1;" type="number" value="{{ruleNoShowDays}}" bindinput="onRuleNoShowDays" bindblur="onRuleNoShowDaysBlur"/>
      </view>
      <view wx:if="{{ruleNoShow}}" class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">取消截止(开赛前小时)</text>
        <input class="input" style="flex:1;" type="number" value="{{ruleCancelDeadline}}" placeholder="不限" bindinput="onRuleCancelDeadline" bindblur="onRuleCancelDeadlineBlur"/>
      </view>
      <view wx:if="{{ruleNoShow}}" class="muted" style="margin-top:8rpx;font-size:24rpx;">过了取消截止时间再取消（或未到场），算缺席并禁报</view>

      <view class="row" style="margin-top:16rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">级别限制</text>
        <picker bindchange="onRuleLevelModeChange" value="{{ruleLevelMode==='whitelist'?1:ruleLevelMode==='min'?2:0}}" range="{{['不限制','指定水平','某级以上']}}">
          <view class="input" style="flex:1;">{{ruleLevelMode==='min'?'某级以上':ruleLevelMode==='whitelist'?'指定水平':'不限制'}}</view>
        </picker>
      </view>
      <view wx:if="{{ruleLevelMode==='whitelist'}}" class="row" style="margin-top:12rpx;flex-wrap:wrap;">
        <view wx:for="{{levelOptions}}" wx:key="*this" data-level="{{item}}" bindtap="toggleRuleLevelItem"
              class="tag {{ruleLevels.indexOf(item) >= 0 ? 'tag-open' : 'tag-wait'}}" style="margin:6rpx 8rpx 0 0;">{{item}}</view>
      </view>
      <view wx:if="{{ruleLevelMode==='min'}}" class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:160rpx;">最低水平</text>
        <picker bindchange="onRuleMinLevelChange" value="{{levelOptions.indexOf(ruleMinLevel)}}" range="{{levelOptions}}">
          <view class="input" style="flex:1;">{{ruleMinLevel}}</view>
        </picker>
      </view>
      <view wx:if="{{ruleLevelMode==='min' && ruleMinLevelDesc}}" class="muted" style="margin-top:6rpx;font-size:22rpx;">{{ruleMinLevelDesc}} 及以上可报名</view>

      <view class="row" style="margin-top:16rpx;align-items:center;">
        <switch checked="{{ruleGender}}" bindchange="toggleRuleGender" color="#16a34a"/>
        <text style="margin-left:16rpx;">性别限制</text>
      </view>
      <view wx:if="{{ruleGender}}" class="row" style="margin-top:12rpx;flex-wrap:wrap;">
        <view wx:for="{{['男','女']}}" wx:key="*this" data-gender="{{item}}" bindtap="toggleRuleGenderItem"
              class="tag {{ruleGenders.indexOf(item) >= 0 ? 'tag-open' : 'tag-wait'}}" style="margin:6rpx 8rpx 0 0;">{{item}}</view>
      </view>
      <view wx:if="{{ruleGender}}" class="muted" style="margin-top:8rpx;font-size:24rpx;">没填或"不公开"性别的会被拦</view>
    </view>
  </view>

  <button class="btn btn-primary" bindtap="submit" disabled="{{submitting}}">{{editId ? '保存修改' : '发起活动'}}</button>
</view>
