.club-modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.club-modal {
  background: #fff;
  width: 100%;
  max-height: 70vh;
  overflow-y: auto;
  padding: 24rpx;
  border-radius: 24rpx 24rpx 0 0;
}
