.profile-head {
  display: flex;
  align-items: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: normal;
}
.avatar-btn::after {
  border: none;
}

.big-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}
.big-avatar-fallback {
  background: #dcfce7;
  color: #16a34a;
  font-size: 28rpx;
  text-align: center;
  line-height: 120rpx;
}

.nickname-input {
  font-size: 34rpx;
  font-weight: 600;
  padding: 6rpx 0;
}

.title-md {
  font-size: 30rpx;
  font-weight: 600;
}

.field-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}
.field-row:first-child {
  margin-top: 0;
}
.field-row .field-label {
  width: 120rpx;
  color: #6b7280;
}
.picker-val {
  color: #374151;
}

/* 水平 radio 单选（每个选项：单选圈 + 名称 + 说明）*/
.level-block {
  margin-top: 16rpx;
}
.level-block .field-label {
  color: #6b7280;
  margin-bottom: 2rpx;
}
.level-group {
  display: flex;
  flex-direction: column;
}
.level-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}
.level-name {
  font-size: 24rpx;
  /*  font-weight: 400;  不加粗，正常即可 */
  margin-left: 10rpx;
  color: #374151;
}
.level-desc {
  font-size: 24rpx;
  margin-left: 14rpx;
}

/* 性别 radio（横向一行）*/
.gender-group {
  display: flex;
  align-items: center;
}
.gender-radio {
  display: flex;
  align-items: center;
  margin-right: 28rpx;
}
.gender-label {
  font-size: 28rpx;
  font-weight: 400;
  margin-left: 8rpx;
  color: #374151;
}
