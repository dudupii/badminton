<view class="container">
  <!-- profile header -->
  <view class="card profile-head">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{user.avatarUrl}}" class="big-avatar" src="{{user.avatarUrl}}" />
      <view wx:else class="big-avatar big-avatar-fallback">头像</view>
    </button>
    <view style="flex:1;margin-left:24rpx;">
      <input
        type="nickname"
        class="nickname-input"
        placeholder="点击设置昵称"
        value="{{user.nickname}}"
        bindinput="onNicknameInput"
        bindblur="onNicknameBlur"
      />
      <view class="muted" style="margin-top:8rpx;">用微信身份报名活动</view>
    </view>
  </view>

  <!-- level / gender tags -->
  <view class="card">
    <view class="level-block">
      <view class="field-label">水平</view>
      <radio-group bindchange="onLevelChange" class="level-group">
        <label class="level-row" wx:for="{{levelOptions}}" wx:key="name">
          <radio value="{{item.name}}" checked="{{item.name === user.level}}" color="#16a34a"/>
          <text class="level-name">{{item.name}}</text>
          <text class="muted level-desc">{{item.desc}}</text>
        </label>
      </radio-group>
    </view>
    <view class="field-row">
      <view class="field-label">性别</view>
      <radio-group bindchange="onGenderChange" class="gender-group">
        <label class="gender-radio" wx:for="{{genders}}" wx:key="*this">
          <radio value="{{item}}" checked="{{item === user.gender}}" color="#16a34a"/>
          <text class="gender-label">{{item}}</text>
        </label>
      </radio-group>
    </view>
  </view>

  <!-- 球友群入口（暂隐藏：UI 不显示，后端 clubs 接口保留。恢复去掉外层注释即可）-->
  <!--
  <view class="card" bindtap="goClubs" style="margin-bottom:16rpx;">
    <view class="row between">
      <text class="title-md">球友群</text>
      <text class="muted">管理 ›</text>
    </view>
  </view>
  -->

  <!-- 出勤统计入口 -->
  <view class="card" bindtap="goStats" style="margin-bottom:16rpx;">
    <view class="row between">
      <text class="title-md">出勤统计</text>
      <text class="muted">我发起的活动 ›</text>
    </view>
  </view>

  <!-- my registrations -->
  <view class="section-title" style="margin:8rpx 8rpx 16rpx;">我的报名</view>

  <block wx:if="{{regs.length}}">
    <view
      class="card"
      wx:for="{{regs}}"
      wx:key="activity.id"
      data-id="{{item.activity.id}}"
      bindtap="goDetail"
    >
      <view class="row between">
        <text class="title-md">{{item.activity.title}}</text>
        <text class="tag tag-open" wx:if="{{item.status === 'confirmed'}}">正式</text>
        <text class="tag tag-wait" wx:else>候补</text>
      </view>
      <view class="muted" style="margin-top:10rpx;">⏰ {{item.timeText}}</view>
    </view>
  </block>

  <view wx:elif="{{!loading}}" class="empty">还没有报名任何活动</view>

  <!-- my activities (created by me) -->
  <view class="section-title" style="margin:24rpx 8rpx 16rpx;">我的活动</view>

  <block wx:if="{{myActs.length}}">
    <view
      class="card"
      wx:for="{{myActs}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <view class="row between">
        <text class="title-md">{{item.title}}</text>
        <text class="tag tag-open" wx:if="{{item.status === 'open'}}">报名中</text>
        <text class="tag tag-closed" wx:else>已关闭</text>
      </view>
      <view class="muted" style="margin-top:10rpx;">⏰ {{item.timeText}}</view>
    </view>
  </block>

  <view wx:elif="{{!loading}}" class="empty">还没有创建任何活动</view>
</view>
