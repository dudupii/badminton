<view class="container" wx:if="{{detail}}">
  <!-- header -->
  <view class="card">
    <view class="row between">
      <text class="title-lg">{{detail.title}}</text>
      <text class="tag tag-closed" wx:if="{{detail.status === 'closed'}}">等待中</text>
      <text class="tag tag-open" wx:elif="{{!isPast}}">报名中</text>
      <text class="tag tag-closed" wx:else>已结束</text>
    </view>
    <view class="info-line">⏰ {{detail.timeText}}<text wx:if="{{detail.endText}}"> ～ {{detail.endText}}</text></view>
    <view class="info-line" wx:if="{{detail.location}}" bindtap="copyLocation">📍 {{detail.location}} <text class="muted">（点击复制）</text></view>
    <view class="row between" style="margin-top:16rpx;">
      <view>
        <text style="color:#16a34a;font-weight:600;font-size:30rpx;">{{detail.confirmedCount}}/{{detail.capacity}}</text>
        <text class="muted"> 已报名</text>
        <text wx:if="{{detail.waitlistCount}}" class="muted"> · 候补 {{detail.waitlistCount}}</text>
      </view>
    </view>
    <view wx:if="{{genderCount.male || genderCount.female}}" class="muted" style="margin-top:6rpx;font-size:24rpx;">男 {{genderCount.male}} · 女 {{genderCount.female}}</view>
    <view class="info-line desc-line" wx:if="{{detail.description}}">
      <text class="desc-label">活动说明：</text>{{detail.description}}
    </view>
  </view>

  <!-- confirmed roster -->
  <view class="card">
    <view class="section-title">正式名单（{{detail.confirmedCount}}/{{detail.capacity}}）</view>
    <block wx:if="{{detail.confirmed.length}}">
      <view class="roster-item" wx:for="{{detail.confirmed}}" wx:key="openid">
        <text class="roster-no">{{index + 1}}</text>
        <image wx:if="{{item.avatarUrl}}" class="avatar" src="{{item.avatarUrl}}" />
        <view wx:else class="avatar avatar-fallback">{{item.nickname ? item.nickname[0] : '?'}}</view>
        <text class="roster-name">{{item.nickname}}</text>
        <text wx:if="{{item.level}}" class="tag tag-level">{{item.level}}</text>
        <text wx:if="{{item.gender}}" class="tag tag-gender {{item.gender === '男' ? 'tg-male' : 'tg-female'}}">{{item.gender}}</text>
        <text wx:if="{{item.openid === detail.createdBy}}" class="tag tag-open">发起人</text>
      </view>
    </block>
    <view wx:else class="muted" style="padding:8rpx 0;">还没有人报名</view>
  </view>

  <!-- waitlist -->
  <view class="card" wx:if="{{detail.waitlist.length}}">
    <view class="section-title">候补名单（{{detail.waitlistCount}}）</view>
    <view class="roster-item" wx:for="{{detail.waitlist}}" wx:key="openid">
      <text class="roster-no muted">{{index + 1}}</text>
      <image wx:if="{{item.avatarUrl}}" class="avatar" src="{{item.avatarUrl}}" />
      <view wx:else class="avatar avatar-fallback">{{item.nickname ? item.nickname[0] : '?'}}</view>
      <text class="roster-name">{{item.nickname}}</text>
      <text class="muted">候补</text>
    </view>
  </view>

  <!-- 费用 AA（仅发起人） -->
  <view class="card" wx:if="{{isCreator}}">
    <view class="section-title">费用 AA</view>
    <view class="row" style="margin-top:12rpx;align-items:center;">
      <text class="muted" style="width:140rpx;">计费</text>
      <picker bindchange="onFeeModeChange" value="{{feeEdit.mode==='fixed'?1:0}}" range="{{['总额均摊','固定人均']}}">
        <view class="input" style="flex:1;">{{feeEdit.mode==='fixed'?'固定人均':'总额均摊'}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top:12rpx;align-items:center;">
      <text class="muted" style="width:140rpx;">{{feeEdit.mode==='fixed'?'人均(元)':'总额(元)'}}</text>
      <input class="input" style="flex:1;" type="digit" value="{{feeEdit.amount}}" placeholder="留空清除" bindinput="onFeeAmount" />
    </view>
    <view class="row" style="margin-top:12rpx;align-items:center;">
      <text class="muted" style="width:140rpx;">分摊</text>
      <picker bindchange="onFeeSplitChange" value="{{feeEdit.splitBy==='attended'?1:0}}" range="{{['按正式名单','按实到名单']}}">
        <view class="input" style="flex:1;">{{feeEdit.splitBy==='attended'?'按实到名单':'按正式名单'}}</view>
      </picker>
    </view>
    <button class="btn btn-primary" style="margin-top:16rpx;" bindtap="saveFee">保存费用</button>
    <view wx:if="{{feeSummary && feeSummary.totalOwedCents > 0}}" class="muted" style="margin-top:16rpx;">
      应收 ¥{{feeSummary.totalOwedCents/100}} · 已收 ¥{{feeSummary.totalPaidCents/100}} · {{feeSummary.settled?'已结清':'未结清'}}
    </view>
    <block wx:if="{{detail.confirmed.length}}">
      <view class="roster-item" wx:for="{{detail.confirmed}}" wx:key="openid">
        <text class="roster-name">{{item.nickname}}</text>
        <text class="muted">应付¥{{item.owedCents/100}}</text>
        <text class="tag {{item.paid?'tag-open':'tag-wait'}}" data-openid="{{item.openid}}" data-paid="{{item.paid}}" bindtap="togglePaid" style="margin-left:12rpx;">{{item.paid?'已付':'未付'}}</text>
        <text class="tag {{item.attended===true?'tag-open':item.attended===false?'tag-closed':'tag-wait'}}" data-openid="{{item.openid}}" data-attended="{{item.attended}}" bindtap="toggleAttend" style="margin-left:8rpx;">{{item.attended===true?'到':item.attended===false?'缺':'未签'}}</text>
      </view>
    </block>
    <button class="btn btn-ghost" style="margin-top:16rpx;" bindtap="exportFee">导出费用表(CSV)</button>
  </view>

  <!-- 水平分组（仅发起人） -->
  <view class="card" wx:if="{{isCreator && detail.confirmed.length}}">
    <view class="section-title">水平分组</view>
    <view class="row" style="margin-top:12rpx;align-items:center;">
      <text class="muted" style="width:140rpx;">模式</text>
      <picker bindchange="onGroupModeChange" value="{{groupMode==='pairs'?1:groupMode==='rotation'?2:0}}" range="{{['分N组(场地)','双打搭档','轮转表']}}">
        <view class="input" style="flex:1;">{{groupMode==='rotation'?'轮转表':groupMode==='pairs'?'双打搭档':'分N组(场地)'}}</view>
      </picker>
    </view>
    <view class="row" wx:if="{{groupMode==='groups'}}" style="margin-top:12rpx;align-items:center;">
      <text class="muted" style="width:140rpx;">组数</text>
      <input class="input" style="flex:1;" type="number" value="{{groupCount}}" bindinput="onGroupCount" bindblur="onGroupCountBlur" />
    </view>
    <button class="btn btn-primary" style="margin-top:16rpx;" bindtap="genGroups">生成</button>
    <block wx:if="{{grouping}}">
      <view wx:for="{{grouping.groups}}" wx:for-item="grp" wx:key="id" style="margin-top:16rpx;">
        <view class="muted" style="font-weight:600;">{{grouping.mode==='pairs' ? (grp.members.length===1 ? '落单' : '搭档') : '组'}} {{index+1}}</view>
        <view wx:for="{{grp.members}}" wx:for-item="p" wx:key="openid" style="padding:4rpx 0;">
          {{p.nickname}}（{{p.level||'未填'}}）
        </view>
      </view>
    </block>

    <block wx:if="{{groupMode === 'rotation'}}">
      <view class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:140rpx;">场地数</text>
        <input class="input" style="flex:1;" type="number" value="{{rotCourts}}" bindinput="onRotCourts" bindblur="onRotCourtsBlur"/>
      </view>
      <view class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:140rpx;">轮数</text>
        <input class="input" style="flex:1;" type="number" value="{{rotRounds}}" bindinput="onRotRounds" bindblur="onRotRoundsBlur"/>
      </view>
      <view class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:140rpx;">水平</text>
        <picker bindchange="onRotLevelMode" value="{{rotLevelMode==='balanced'?1:0}}" range="{{['同质(相近同场)','均衡(强弱搭)']}}">
          <view class="input" style="flex:1;">{{rotLevelMode==='balanced'?'均衡(强弱搭)':'同质(相近同场)'}}</view>
        </picker>
      </view>
      <view class="row" style="margin-top:12rpx;align-items:center;">
        <text class="muted" style="width:140rpx;">赛制</text>
        <picker bindchange="onRotMatchFormat" value="{{rotMatchFormat==='mens'?1:rotMatchFormat==='womens'?2:rotMatchFormat==='mixed'?3:0}}" range="{{['不限','男双','女双','混双']}}">
          <view class="input" style="flex:1;">{{rotMatchFormat==='mens'?'男双':rotMatchFormat==='womens'?'女双':rotMatchFormat==='mixed'?'混双':'不限'}}</view>
        </picker>
      </view>

      <view class="muted" style="margin-top:16rpx;font-size:24rpx;">固定搭档（可选）：点一人、再点另一人配对；点已配对人解除</view>
      <view class="row" style="margin-top:8rpx;flex-wrap:wrap;">
        <view wx:for="{{detail.confirmed}}" wx:key="openid" data-openid="{{item.openid}}" bindtap="toggleRotPair"
              class="tag {{rotFixedFlat.indexOf(item.openid) >= 0 ? 'tag-open' : (rotPairPick === item.openid ? 'tag-wait' : 'tag-level')}}" style="margin:6rpx 8rpx 0 0;">{{item.nickname}}</view>
      </view>
      <view class="muted" wx:if="{{rotPairPick}}" style="margin-top:6rpx;font-size:22rpx;">已选 1 人，再点一人配对…</view>

      <button class="btn btn-primary" style="margin-top:16rpx;" bindtap="genRotation">生成轮转</button>
      <button wx:if="{{detail.rotation}}" class="btn btn-ghost" style="margin-top:12rpx;" bindtap="clearRotation">清除轮转</button>

      <block wx:if="{{detail.rotation}}">
        <view wx:for="{{detail.rotation.schedule}}" wx:for-item="round" wx:key="*this" style="margin-top:16rpx;">
          <view class="muted" style="font-weight:600;">第 {{index+1}} 轮</view>
          <view wx:for="{{round}}" wx:for-item="court" wx:for-index="ci" wx:key="*this" style="padding:4rpx 0;">
            <text class="muted">场{{ci+1}}：</text>{{court[0].no}}-{{court[0].nickname}}{{court[1] ? ' / ' + court[1].no + '-' + court[1].nickname : ''}}{{court[2] ? ' / ' + court[2].no + '-' + court[2].nickname : ''}}{{court[3] ? ' / ' + court[3].no + '-' + court[3].nickname : ''}}
          </view>
        </view>
      </block>
    </block>
  </view>

  <!-- invite QR -->
  <view class="card qr-card">
    <view class="section-title">邀请报名</view>
    <view class="qr-wrap">
      <image
        class="qr-img"
        src="{{qrcodeUrl}}"
        mode="aspectFit"
        show-menu-by-longpress="{{true}}"
      />
    </view>
    <view class="muted qr-tip">扫一扫二维码，或转发给微信好友，对方即可报名</view>
    <view class="row qr-actions">
      <button class="btn btn-ghost qr-btn" bindtap="saveQrToAlbum">保存二维码</button>
      <button class="btn btn-primary qr-btn" open-type="share">转发给好友</button>
    </view>
    <button class="btn btn-ghost" style="margin-top:18rpx;" bindtap="generatePoster">生成活动海报</button>
  </view>

  <view class="muted" wx:if="{{myFee}}" style="margin:8rpx 16rpx;font-size:26rpx;">我的费用：应付 ¥{{myFee.owedCents/100}} · {{myFee.paid?'已付':'待付'}}</view>

  <view wx:if="{{detail.rules && detail.rules.noShowBanDays}}" class="card" style="background:#fef3c7;padding:20rpx;margin:8rpx 0;">
    <text style="color:#b45309;font-size:25rpx;">⚠️ 缺席惩罚：{{detail.rules.cancelDeadlineHours ? '开赛前 ' + detail.rules.cancelDeadlineHours + ' 小时后取消或' : ''}}未到场，将 {{detail.rules.noShowBanDays}} 天内无法报名该组织者的活动</text>
  </view>

  <!-- my status + actions -->
  <view class="action-bar">
    <block wx:if="{{detail.myStatus === 'confirmed'}}">
      <view class="my-status confirmed">✓ 你已报名（正式名额）</view>
      <button class="btn btn-danger" bindtap="doCancel">取消报名</button>
    </block>
    <block wx:elif="{{detail.myStatus === 'waitlist'}}">
      <view class="my-status waitlist">你排在候补第 {{myWaitPos}} 位，有人取消时自动上位</view>
      <button class="btn btn-danger" bindtap="doCancel">取消候补</button>
    </block>
    <block wx:elif="{{detail.status === 'closed'}}">
      <button class="btn btn-ghost" disabled>报名已关闭</button>
    </block>
    <block wx:elif="{{isPast}}">
      <button class="btn btn-ghost" disabled>活动已开始</button>
    </block>
    <block wx:else>
      <button class="btn btn-primary" bindtap="doRegister">
        {{detail.confirmedCount >= detail.capacity ? '加入候补' : '立即报名'}}
      </button>
    </block>

    <button wx:if="{{isCreator}}" class="btn btn-ghost" style="margin-top:18rpx;" bindtap="goEdit">
      编辑活动
    </button>
    <button wx:if="{{isCreator}}" class="btn btn-ghost" style="margin-top:18rpx;" bindtap="toggleStatus">
      {{detail.status === 'open' ? '关闭报名' : '重新开放报名'}}
    </button>
    <button wx:if="{{isCreator}}" class="btn btn-danger" style="margin-top:18rpx;" bindtap="deleteActivity">
      删除活动
    </button>
  </view>
</view>

<view wx:elif="{{!loading}}" class="empty">活动不存在或已被删除</view>

<!-- 离屏海报画布（不可见，仅用于导出图片）。放在 wx:if/wx:elif 链之后，避免打断两者相邻关系；本身是无条件渲染的离屏节点 -->
<canvas type="2d" id="poster" class="poster-canvas"></canvas>
