.info-line {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 27rpx;
}
.desc-line {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #f3f4f6;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
}
.desc-label {
  color: #6b7280;
  font-weight: 600;
}

.roster-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 2rpx solid #f3f4f6;
}
.roster-item:last-child {
  border-bottom: none;
}
.roster-no {
  width: 48rpx;
  text-align: center;
  font-weight: 600;
  color: #16a34a;
}
.roster-name {
  flex: 1;
  margin-left: 18rpx;
}
.tag-level {
  background: #dbeafe;
  color: #1d4ed8;
}
.tag-gender {
  background: #f3f4f6;
  color: #6b7280;
  margin-left: 8rpx;
}
.tag-gender-男 {
  background: #dbeafe;
  color: #1d4ed8;
}
.tag-gender-女 {
  background: #fce7f3;
  color: #be185d;
}
.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-left: 8rpx;
}
.avatar-fallback {
  background: #dcfce7;
  color: #16a34a;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  line-height: 56rpx;
}

.action-bar {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.my-status {
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  padding: 16rpx;
  border-radius: 12rpx;
}
.my-status.confirmed {
  background: #dcfce7;
  color: #15803d;
}
.my-status.waitlist {
  background: #fef3c7;
  color: #b45309;
}

.qr-card {
  text-align: center;
}
.qr-wrap {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 8rpx;
}
.qr-img {
  width: 360rpx;
  height: 360rpx;
  background: #fff;
}
.qr-tip {
  margin-top: 8rpx;
}
.qr-actions {
  margin-top: 22rpx;
}
.qr-btn {
  flex: 1;
  width: auto;
  margin: 0 8rpx;
}
